<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>OpenClaw Token 用量</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container py-4">
    <h1 class="mb-4">OpenClaw Token 用量</h1>

    <div class="card mb-4">
      <div class="card-header">全局合计</div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-4">
            <strong>总 Input Tokens</strong>: {{ totals.total_input | default(0) }}
          </div>
          <div class="col-md-4">
            <strong>总 Output Tokens</strong>: {{ totals.total_output | default(0) }}
          </div>
          <div class="col-md-4">
            <strong>总成本</strong>: {% if totals.total_cost is not none %}{{ "%.4f" | format(totals.total_cost) }}{% else %}—{% endif %}
          </div>
        </div>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header">按 Agent 汇总</div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped mb-0">
            <thead>
              <tr>
                <th>Agent ID</th>
                <th>会话数</th>
                <th>Input Tokens</th>
                <th>Output Tokens</th>
                <th>成本</th>
              </tr>
            </thead>
            <tbody>
              {% for r in by_agent %}
              <tr>
                <td>{{ r.agent_id }}</td>
                <td>{{ r.session_count }}</td>
                <td>{{ r.total_input }}</td>
                <td>{{ r.total_output }}</td>
                <td>{% if r.total_cost is not none %}{{ "%.4f" | format(r.total_cost) }}{% else %}—{% endif %}</td>
              </tr>
              {% else %}
              <tr><td colspan="5" class="text-muted">无数据</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header">按 Session 明细</div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped mb-0">
            <thead>
              <tr>
                <th>Agent ID</th>
                <th>Session ID</th>
                <th>Input Tokens</th>
                <th>Output Tokens</th>
                <th>成本</th>
                <th>最后活动</th>
              </tr>
            </thead>
            <tbody>
              {% for r in by_session %}
              <tr>
                <td>{{ r.agent_id }}</td>
                <td>{{ r.session_id }}</td>
                <td>{{ r.total_input }}</td>
                <td>{{ r.total_output }}</td>
                <td>{% if r.total_cost is not none %}{{ "%.4f" | format(r.total_cost) }}{% else %}—{% endif %}</td>
                <td>{{ r.last_activity or "—" }}</td>
              </tr>
              {% else %}
              <tr><td colspan="6" class="text-muted">无数据</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <p class="text-muted small">数据来源: OpenClaw session JSONL · 刷新请访问 /refresh 或重新导出</p>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
